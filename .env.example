# PostgreSQL connection string
# Windows example: postgresql://postgres:yourpassword@localhost:5432/bialto
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/bialto

# JWT signing secret — any long random string works
SESSION_SECRET=change_me_to_a_long_random_secret_string

# Object storage (optional — only needed if using Replit Object Storage)
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
